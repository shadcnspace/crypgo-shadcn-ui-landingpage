---
import { perksData } from '../../data/index';
---
<section class="pb-28 relative">
  <div class="container px-4 relative z-[2]">
    <div class="text-center">
      <div class="flex flex-col gap-4">
        <p class="text-white text-base relative">
          Always By <span class="text-primary">your side</span>
        </p>
        <h2 class="text-white sm:text-5xl text-3xl font-medium">
          Be the first to use our Cryogo!
        </h2>
      </div>
      <div
        class="mt-16 border border-border grid lg:grid-cols-3 sm:grid-cols-2 py-16 gap-10 px-20 rounded-3xl bg-center bg-no-repeat"
        style="background-image: url('/images/perks/perk-bg.png')"
      >
        {perksData.map((item) => (
          <div class="text-center flex items-center justify-end flex-col">
            <div class="bg-primary/25 backdrop-blur-sm p-4 rounded-full w-fit">
              <img src={item.icon} alt={item.title} width="44" height="44" />
            </div>
            <h3 class={`text-white text-2xl mb-4 ${item.space}`}>{item.title}</h3>
            <div class="text-white/60" set:html={item.text} />
          </div>
        ))}
      </div>
    </div>
  </div>
  <div class="bg-gradient-to-br from-tealGreen to-charcoalGray sm:w-[200px] w-96 z-0 sm:h-[200px] h-96 rounded-full sm:-bottom-80 bottom-0 blur-[400px] absolute sm:-left-48 opacity-60"></div>
</section>
