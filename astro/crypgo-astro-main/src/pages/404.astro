---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 | CrypGo">
  <div class="min-h-screen flex flex-col items-center justify-center text-center px-4">
    <img src="/images/404.svg" alt="404" class="max-w-md w-full mb-10" />
    <h1 class="text-4xl font-bold text-white mb-4">Page Not Found</h1>
    <p class="text-muted/60 text-lg mb-8">The page you're looking for doesn't exist or has been moved.</p>
    <a
      href="/"
      class="bg-primary text-background px-8 py-3 rounded-lg font-medium hover:bg-primary/80 transition-colors"
    >
      Go Home
    </a>
  </div>
</Layout>
